{
  "name": "@gaqno-development/mastra-runtime",
  "version": "0.2.0",
  "private": false,
  "description": "Shared Mastra runtime (agents, tools, lib, constants, middleware) consumed by gaqno-mastra (operator Studio) and embedded NestJS hosts (gaqno-ai-service first).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaqno-development/gaqno-development-workspace.git",
    "directory": "@gaqno-mastra-runtime"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist",
    "types"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./agents": {
      "types": "./dist/index.d.ts",
      "import": "./dist/agents/index.js"
    },
    "./tools": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./lib": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./constants": {
      "types": "./dist/index.d.ts",
      "import": "./dist/constants/index.js"
    }
  },
  "scripts": {
    "build": "tsup && cp types/index.d.ts dist/index.d.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "peerDependencies": {
    "@mastra/ai-sdk": "^1.4.1",
    "@mastra/duckdb": "^1.2.0",
    "@mastra/core": "^1.30.0",
    "@mastra/libsql": "^1.9.0",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.17.4",
    "@mastra/observability": "^1.10.3",
    "@mastra/qdrant": "^1.0.2",
    "@mastra/rag": "^2.2.1",
    "hono": "^4.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@mastra/ai-sdk": { "optional": true },
    "@mastra/duckdb": { "optional": true }
  },
  "devDependencies": {
    "@mastra/ai-sdk": "^1.4.1",
    "@mastra/duckdb": "^1.2.0",
    "@mastra/core": "^1.30.0",
    "@mastra/libsql": "^1.9.0",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.17.4",
    "@mastra/observability": "^1.10.3",
    "@mastra/qdrant": "^1.0.2",
    "@mastra/rag": "^2.2.1",
    "@types/node": "^22.0.0",
    "hono": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9",
    "zod": "^4.4.1"
  }
}
