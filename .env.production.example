# ============================================================
# Production Environment Variables
# Copy to .env.production and fill in the values
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Auth / Security ─────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
COOKIE_SECRET=CHANGE_ME_RANDOM_32_CHARS
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
COOKIE_DOMAIN=.gaqno.com.br
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
CORS_ORIGIN=https://portal.gaqno.com.br

# ── SSO: n8n webhooks (OTP send/verify, notifications hub) ─
# Base URL only — no path. SSO calls {N8N_WEBHOOK_URL}/webhook/gaqno-auth-otp, /webhook/gaqno-notify, etc.
# Import the notifications hub and auth OTP workflow JSON exports in n8n and activate.
N8N_WEBHOOK_URL=https://n8n.gaqno.com.br

# Reference for n8n workflow 16 (Publish WhatsApp node). Same path the shell uses in production.
OMNICHANNEL_API_BASE_URL=https://api.gaqno.com.br/omnichannel/v1

# Omnichannel: resolve x-tenant-domain to tenant UUID via SSO (GET with ?host=). No trailing slash.
# On Dokploy/Swarm, prefer the internal SSO base (same host as SSO_SERVICE_URL): http://<sso-service>:4001/v1/public/tenant-by-host
SSO_TENANT_BY_HOST_URL=https://api.gaqno.com.br/sso/v1/public/tenant-by-host

# ── Frontend (build-time) ───────────────────────────────────
VITE_APP_ORIGIN=https://portal.gaqno.com.br
NPM_TOKEN=ghp_YOUR_GITHUB_PACKAGES_TOKEN

# ── Cloudflare ──────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=eyJ...YOUR_TUNNEL_TOKEN
# Token for tenant provisioning (DNS + Tunnel writes). Scopes required:
#   Zone:DNS:Edit (zone gaqno.com.br)
#   Account:Cloudflare Tunnel:Edit
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN
CLOUDFLARE_ZONE_ID=d628a8ac60069acccbc154d173b88717
CLOUDFLARE_ACCOUNT_ID=YOUR_ACCOUNT_ID
CLOUDFLARE_TUNNEL_ID=YOUR_TUNNEL_ID
CLOUDFLARE_TUNNEL_TARGET_SERVICE=http://shop-service:4015
CLOUDFLARED_EDGE_NETWORK=dokploy-network

# ── Tenant Provisioning (SSO → Shop internal call) ──────────
SHOP_SERVICE_URL=http://shop-service:4015
SHOP_INTERNAL_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN

# ── Mercado Pago (platform subscription billing) ────────────
# Platform's access token (gaqno's MP account — cobrança da gaqno pro tenant)
MERCADO_PAGO_PLATFORM_ACCESS_TOKEN=APP_USR-xxxxxxxx
MERCADO_PAGO_PLATFORM_WEBHOOK_URL=https://api.gaqno.com.br/sso/v1/subscriptions/webhook/mercado-pago
MERCADO_PAGO_PLATFORM_SUCCESS_URL=https://portal.gaqno.com.br/billing/success

# ── SSO: internal service proxy URLs ────────────────────────
# Used by sso-service to forward cost/usage requests to admin-service and ai-service.
# In Docker Compose use the service name; in Dokploy use the internal hostname.
ADMIN_SERVICE_URL=http://admin-service:4010
AI_SERVICE_URL=http://ai-service:4002

# ── Monitoring ──────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=https://grafana.gaqno.com.br
VITE_GRAFANA_URL=https://grafana.gaqno.com.br
VITE_GRAFANA_API_KEY=
POSTGRES_EXPORTER_URI=postgres:5432/gaqno_sso_db?sslmode=disable
POSTGRES_EXPORTER_USER=postgres
POSTGRES_EXPORTER_PASS=CHANGE_ME_STRONG_PASSWORD

# ── Omnichannel (WhatsApp) ──────────────────────────────────
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
META_ACCESS_TOKEN=

# ── AI Service ──────────────────────────────────────────────
OPENAI_API_KEY=
NEW_RELIC_APP_NAME=
NEW_RELIC_LICENSE_KEY=

# ── Lead Enrichment (Pipedrive) ─────────────────────────────
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=

# ── Finance ─────────────────────────────────────────────────
SEED_TENANT_ID=
FINANCE_SYSTEM_USER_ID=
