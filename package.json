{
  "name": "gaqno-development-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "@gaqno-agent",
    "@gaqno-backcore",
    "@gaqno-frontcore",
    "@gaqno-mastra-runtime",
    "@gaqno-types",
    "gaqno-admin-service",
    "gaqno-admin-ui",
    "gaqno-ai-service",
    "gaqno-ai-ui",
    "gaqno-crm-service",
    "gaqno-crm-ui",
    "gaqno-customer-service",
    "gaqno-docs-ui",
    "gaqno-shop",
    "gaqno-shop-admin",
    "gaqno-erp-service",
    "gaqno-erp-ui",
    "gaqno-finance-service",
    "gaqno-finance-ui",
    "gaqno-intelligence-service",
    "gaqno-intelligence-ui",
    "gaqno-landing-ui",
    "gaqno-lead-enrichment-service",
    "gaqno-lenin-ui",
    "gaqno-omnichannel-service",
    "gaqno-omnichannel-ui",
    "gaqno-pdv-service",
    "gaqno-pdv-ui",
    "gaqno-rpg-service",
    "gaqno-rpg-ui",
    "gaqno-shell-ui",
    "gaqno-sherlock-service",
    "gaqno-sherlock-ui",
    "gaqno-shop-service",
    "gaqno-sso-service",
    "gaqno-sso-ui",
    "gaqno-wellness-service",
    "gaqno-wellness-ui"
  ],
  "scripts": {
    "secret-scan": "gitleaks protect --config .gitleaks.toml --no-git --verbose",
    "prepare": "husky",
    "postinstall": "bash scripts/patch-federation-plugin.sh",
    "install:all": "npm install --legacy-peer-deps",
    "clean": "rm -rf node_modules */node_modules @**/node_modules",
    "build:packages": "npm run build -w @gaqno-development/mastra-runtime && npm run build -w @gaqno-backcore",
    "build:types": "npm run build -w @gaqno-types",
    "build:all": "npm run build -w gaqno-shell-ui && npm run build -w gaqno-sso-ui && npm run build -w gaqno-ai-ui && npm run build -w gaqno-crm-ui && npm run build -w gaqno-erp-ui && npm run build -w gaqno-finance-ui && npm run build -w gaqno-pdv-ui && npm run build -w gaqno-rpg-ui && npm run build -w gaqno-sso-service && npm run build -w gaqno-ai-service && npm run build -w gaqno-crm-service && npm run build -w gaqno-erp-service && npm run build -w gaqno-finance-service && npm run build -w gaqno-pdv-service && npm run build -w gaqno-rpg-service",
    "dev": "turbo run dev --concurrency=25 --filter=!./gaqno-lenin-ui",
    "dev:backends": "turbo run dev --concurrency=13 --filter=./gaqno-sso-service --filter=./gaqno-ai-service --filter=./gaqno-erp-service --filter=./gaqno-finance-service --filter=./gaqno-pdv-service --filter=./gaqno-rpg-service",
    "dev:frontends": "turbo run dev --concurrency=13 --filter=./gaqno-shell-ui --filter=./gaqno-sso-ui --filter=./gaqno-ai-ui --filter=./gaqno-crm-ui --filter=./gaqno-erp-ui --filter=./gaqno-finance-ui --filter=./gaqno-pdv-ui --filter=./gaqno-rpg-ui",
    "dev:shell": "npm run dev -w gaqno-shell-ui",
    "dev:ai": "npm run dev -w gaqno-ai-ui",
    "dev:crm": "npm run dev -w gaqno-crm-ui",
    "dev:erp": "npm run dev -w gaqno-erp-ui",
    "dev:finance": "npm run dev -w gaqno-finance-ui",
    "dev:pdv": "npm run dev -w gaqno-pdv-ui",
    "dev:sso": "npm run dev -w gaqno-sso-ui",
    "dev:sso-service": "npm run start:dev -w gaqno-sso-service",
    "dev:ai-service": "npm run start:dev -w gaqno-ai-service",
    "dev:finance-service": "npm run start:dev -w gaqno-finance-service",
    "dev:pdv-service": "npm run start:dev -w gaqno-pdv-service",
    "dev:rpg-service": "npm run start:dev -w gaqno-rpg-service",
    "dev:erp-service": "npm run start:dev -w gaqno-erp-service",
    "dev:wellness": "npm run dev -w gaqno-wellness-ui",
    "dev:wellness-service": "npm run start:dev -w gaqno-wellness-service",
    "dev:omnichannel": "npm run dev -w gaqno-omnichannel-ui",
    "dev:admin": "npm run dev -w gaqno-admin-ui",
    "dev:docs": "npm run dev -w gaqno-docs-ui",
    "dev:crm-service": "npm run start:dev -w gaqno-crm-service",
    "dev:omnichannel-service": "npm run start:dev -w gaqno-omnichannel-service",
    "dev:admin-service": "npm run start:dev -w gaqno-admin-service",
    "dev:sherlock": "npm run dev -w gaqno-sherlock-ui",
    "dev:sherlock-service": "npm run start:dev -w gaqno-sherlock-service",
    "dev:dropshipping": "npm run dev -w gaqno-dropshipping",
    "dev:dropshipping-service": "npm run start:dev -w gaqno-dropshipping-service",
    "release:packages": "./publish-packages.sh",
    "publish:frontcore": "sh -c 'set -a && [ -f .env ] && . ./.env && set +a && npm publish -w @gaqno-development/frontcore'",
    "publish:agent": "npm publish -w @gaqno-development/gaqno-agent",
    "publish:types": "npm run build:types && npm publish -w @gaqno-development/types --access restricted",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "verify:local": "npm run verify:production -w gaqno-shell-ui",
    "check:page-structure": "node scripts/run-page-structure-checks.mjs"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jest-util": "^29.7.0",
    "reflect-metadata": "^0.1.14",
    "turbo": "^2.3.0"
  },
  "dependencies": {
    "rxjs": "^7.8.2"
  }
}
