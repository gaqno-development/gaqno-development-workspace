    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json?.body ?? $input.first().json;\nreturn [{\n  json: {\n    tenantId: body.tenantId,\n    provider: body.provider,\n    accessToken: body.accessToken,\n    instanceUrl: body.instanceUrl || 'https://login.salesforce.com',\n    crmAuthToken: body.crmAuthToken,\n    crmBaseUrl: body.crmBaseUrl || 'http://localhost:4003'\n  }\n}];"
      },
      "id": "d0e1f2a3-0011-4000-8000-000000000002",
      "name": "Extract params",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.instanceUrl }}/services/data/v59.0/query?q=SELECT+Id,Name,Email,Phone,Account.Name+FROM+Contact+LIMIT+200",
        "options": {},
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.accessToken }}" }
          ]
        }
      },
      "id": "d0e1f2a3-0011-4000-8000-000000000003",
      "name": "Fetch SF Contacts",
